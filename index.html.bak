<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>fake-data-generator | Made by Lumi</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>💡 fake-data-generator</h1>
        <p class="subtitle">Generate realistic fake data for testing</p>
        
        <div class="tool-box">
            <textarea id="input" placeholder="Enter your text here..."></textarea>
            <div class="options">
                <label>
                    <input type="checkbox" id="option1"> Option 1
                </label>
            </div>
            <button onclick="process()">Process</button>
            <div id="result" class="result"></div>
            <button onclick="copy()" class="secondary">Copy Result</button>
        </div>
        
        <footer>
            Made with 💡 by <a href="https://github.com/Agent-Lumi">Lumi</a>
        </footer>
    </div>
    <script src="app.js"></script>
</body>
</html>
<script>
// Dark mode toggle
const darkModeToggle = document.createElement('button');
darkModeToggle.textContent = '🌙';
darkModeToggle.style.cssText = 'position:fixed;top:20px;right:20px;background:none;border:none;font-size:24px;cursor:pointer;z-index:1000;';
darkModeToggle.onclick = () => {
    document.body.classList.toggle('dark-mode');
    darkModeToggle.textContent = document.body.classList.contains('dark-mode') ? '☀️' : '🌙';
    localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
};
document.body.appendChild(darkModeToggle);

// Check saved preference
if (localStorage.getItem('darkMode') === 'true') {
    document.body.classList.add('dark-mode');
    darkModeToggle.textContent = '☀️';
}
</script>
<style>
.dark-mode { background: #1a1a1a !important; color: #e0e0e0 !important; }
.dark-mode .container { background: #2a2a2a !important; }
</style>
<script>
// Auto-save to localStorage
const saveKey = 'app-data-' + location.pathname;
const saveData = () => {
    const data = { timestamp: Date.now(), inputs: {} };
    document.querySelectorAll('input, textarea').forEach(el => {
        data.inputs[el.id || el.name] = el.value;
    });
    localStorage.setItem(saveKey, JSON.stringify(data));
};
const loadData = () => {
    const saved = localStorage.getItem(saveKey);
    if (saved) {
        const data = JSON.parse(saved);
        Object.entries(data.inputs).forEach(([key, value]) => {
            const el = document.getElementById(key) || document.querySelector('[name="' + key + '"]');
            if (el) el.value = value;
        });
    }
};
document.addEventListener('input', saveData);
document.addEventListener('DOMContentLoaded', loadData);
</script>
<script>
// Keyboard shortcuts
document.addEventListener('keydown', (e) => {
    if (e.ctrlKey || e.metaKey) {
        switch(e.key) {
            case 's': e.preventDefault(); console.log('Save shortcut'); break;
            case 'r': e.preventDefault(); location.reload(); break;
            case 'f': e.preventDefault(); document.querySelector('input')?.focus(); break;
        }
    }
});
</script>
